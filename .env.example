# Telegram Bot Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# Ollama 本地模型配置（推荐用于中文 RAG）
# ============================================================

# 是否使用 Ollama 本地模型（true/false）
# true: 使用本地 Ollama 模型（免费、离线、隐私）
# false: 使用 OpenAI API（需要 API Key，在线）
USE_OLLAMA=false

# Ollama 模型名称（仅当 USE_OLLAMA=true 时生效）
# 推荐模型：
#   - qwen2.5:14b  （推荐，中文最佳，8-10GB 内存）
#   - qwen2.5:32b  （更强，16-20GB 内存）
#   - qwen2.5:7b   （快速，4-6GB 内存）
#   - llama3.1:8b  （英文好，6-8GB 内存）
OLLAMA_MODEL=qwen2.5:14b

# ============================================================
# 使用说明
# ============================================================
# 
# 方案 1：使用 OpenAI API（默认）
# USE_OLLAMA=false
# OPENAI_API_KEY=your_api_key_here
#
# 方案 2：使用 Ollama 本地模型（推荐）
# 1. 安装 Ollama: https://ollama.ai/
# 2. 拉取模型: ollama pull qwen2.5:14b
# 3. 配置环境变量:
#    USE_OLLAMA=true
#    OLLAMA_MODEL=qwen2.5:14b
# 4. 删除旧知识库: rm -rf historical_knowledge/ realtime_knowledge/
# 5. 重启应用: python gui_app_enhanced.py
#
# 详细说明请查看: Ollama模型配置指南.md
# ============================================================

# Docker Configuration (Optional)
# Set a custom user agent for web requests
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Database Configuration (Optional)
# DATABASE_URL=sqlite:///user_data.db
